root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,mjs,cjs,json,css,scss,md,prisma,yml,yaml}]
charset = utf-8
end_of_line = lf

[*.{ps1,psm1,psd1}]
charset = utf-8
end_of_line = lf

[*.md]
trim_trailing_whitespace = false
