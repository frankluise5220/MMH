FROM docker:28-cli

RUN apk add --no-cache git nodejs

WORKDIR /updater
COPY scripts/mmh-updater-server.mjs /updater/mmh-updater-server.mjs

EXPOSE 7788

ENTRYPOINT []
CMD ["sh", "-lc", "if [ -f /workspace/scripts/mmh-updater-server.mjs ]; then exec node /workspace/scripts/mmh-updater-server.mjs; fi; exec node /updater/mmh-updater-server.mjs"]
