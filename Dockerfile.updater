FROM docker:28-cli

ARG APP_COMMIT=unknown
ARG APP_COMMIT_MESSAGE=""
ARG APP_COMMIT_DATE=""

LABEL org.opencontainers.image.title="MMH Updater"
LABEL org.opencontainers.image.source="https://github.com/frankluise5220/MMH"
LABEL org.opencontainers.image.revision=${APP_COMMIT}
LABEL org.opencontainers.image.created=${APP_COMMIT_DATE}
LABEL org.opencontainers.image.description=${APP_COMMIT_MESSAGE}

RUN apk add --no-cache git nodejs

WORKDIR /updater
COPY scripts/mmh-updater-server.mjs /updater/mmh-updater-server.mjs
COPY deploy/nas/docker-compose.yml /updater/deploy/docker-compose.yml
COPY deploy/nas/postgres-entrypoint.sh /updater/deploy/postgres-entrypoint.sh

EXPOSE 7788

ENTRYPOINT []
CMD ["sh", "-lc", "git config --global --add safe.directory /workspace >/dev/null 2>&1 || true; if [ -f /updater/mmh-updater-server.mjs ]; then exec node /updater/mmh-updater-server.mjs; fi; exec node /workspace/scripts/mmh-updater-server.mjs"]
