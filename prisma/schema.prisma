generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AccessKey {
  id        String   @id @default(cuid())
  name      String
  key       String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([createdAt])
  @@index([key])
}

model Account {
  id                                                         String              @id @default(cuid())
  name                                                       String
  balance                                                    Decimal             @default(0) @db.Decimal(18, 2)
  kind                                                       AccountKind         @default(other)
  debtDirection                                              DebtDirection?
  currency                                                   String              @default("CNY")
  isActive                                                   Boolean             @default(true)
  isPlaceholder                                              Boolean             @default(false)
  investProductType                                          FundProductType?
  creditLimit                                                Decimal?            @db.Decimal(18, 2)
  billingDay                                                 Int?
  repaymentDay                                               Int?
  numberMasked                                               String?
  householdId                                                String
  institutionId                                              String?
  userId                                                     String?
  groupId                                                    String
  createdAt                                                  DateTime            @default(now())
  updatedAt                                                  DateTime            @default(now()) @updatedAt
  costBasisMethod                                            CostBasisMethod?
  defaultConfirmDays                                         Int?
  defaultArrivalDays                                         Int?
  defaultFundQueryApiId                                      String?
  fundUnitsDecimals                                          Int                 @default(3)
  FundQueryApi                                               FundQueryApi?       @relation(fields: [defaultFundQueryApiId], references: [id], onDelete: SetNull)
  AccountGroup                                               AccountGroup        @relation(fields: [groupId], references: [id])
  Household                                                  Household           @relation(fields: [householdId], references: [id])
  Institution                                                Institution?        @relation(fields: [institutionId], references: [id])
  User                                                       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  AccountAlias                                               AccountAlias[]
  BillOverride                                               BillOverride[]
  CreditCardCycle                                            CreditCardCycle[]
  FundConfirmDays                                            FundConfirmDays[]
  FundFeeRate                                                FundFeeRate[]
  FundHolding                                                FundHolding[]
  FundSnapshot                                               FundSnapshot[]
  InsuranceProduct                                           InsuranceProduct[]
  RegularInvestPlan_RegularInvestPlan_accountIdToAccount     RegularInvestPlan[] @relation("RegularInvestPlan_accountIdToAccount")
  RegularInvestPlan_RegularInvestPlan_cashAccountIdToAccount RegularInvestPlan[] @relation("RegularInvestPlan_cashAccountIdToAccount")
  transactions_accountIdToAccount                            TxRecord[]          @relation("transactions_accountIdToAccount")
  transactions_toAccountIdToAccount                          TxRecord[]          @relation("transactions_toAccountIdToAccount")

  @@index([householdId, kind])
  @@index([householdId, name])
}

model AccountAlias {
  id        String   @id @default(cuid())
  alias     String
  accountId String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  Account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([alias, accountId])
  @@index([accountId])
  @@index([alias])
}

model AccountGroup {
  id          String    @id @default(cuid())
  name        String
  sortOrder   Int       @default(0)
  householdId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  Account     Account[]
  InsuranceProduct InsuranceProduct[]
  Household   Household @relation(fields: [householdId], references: [id])
}

model AiChannel {
  id          String    @id @default(cuid())
  name        String
  channelType String    @default("custom") // openai | anthropic | deepseek | qwen | ollama | local | custom
  baseUrl     String
  apiKey      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  AiModel     AiModel[]

  @@index([createdAt])
}

model AiModel {
  id        String    @id @default(cuid())
  model     String
  name      String?
  channelId String
  vision    Boolean   @default(false)
  active    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  AiChannel AiChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([active])
  @@index([channelId])
}

model Attachment {
  id           String   @id @default(cuid())
  name         String?
  mimeType     String?
  url          String?
  createdAt    DateTime @default(now())
  entryId      String
  updatedAt    DateTime @default(now()) @updatedAt
  transactions TxRecord @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model BillOverride {
  id             String   @id @default(cuid())
  accountId      String
  statementMonth String
  amount         Decimal  @db.Decimal(18, 2)
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  Account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, statementMonth])
  @@index([accountId])
  @@index([statementMonth])
}

model Category {
  id             String     @id @default(cuid())
  name           String
  type           String
  icon           String?
  parentId       String?
  householdId    String?
  isSystem       Boolean    @default(false)
  Household      Household? @relation(fields: [householdId], references: [id])
  Category       Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  other_Category Category[] @relation("CategoryToCategory")
  transactions   TxRecord[]

  @@index([householdId, type, name])
}

model CreditCardCycle {
  id                 String    @id @default(cuid())
  accountId          String
  statementMonth     String    @db.VarChar(7)
  periodStart        DateTime
  periodEnd          DateTime
  dueDate            DateTime?
  expenseAbs         Decimal   @default(0) @db.Decimal(18, 2)
  income             Decimal   @default(0) @db.Decimal(18, 2)
  paid               Decimal   @default(0) @db.Decimal(18, 2)
  rawBill            Decimal   @default(0) @db.Decimal(18, 2)
  effectiveBill      Decimal   @default(0) @db.Decimal(18, 2)
  cumulativeRemain   Decimal   @default(0) @db.Decimal(18, 2)
  cumulativeOverpaid Decimal   @default(0) @db.Decimal(18, 2)
  isCurrentCycle     Boolean   @default(false)
  isLocked           Boolean   @default(false)
  lockSource         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt
  Account            Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, statementMonth])
  @@index([accountId])
  @@index([isCurrentCycle])
  @@index([statementMonth])
}

model DistillLog {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  source        String    @default("chat")
  rawInput      String
  preprocessed  String?
  promptSent    String?
  llmResponse   String?
  parsedItems   String?
  operationType String?
  finalResult   String?
  trace         String?
  modelName     String?
  latencyMs     Int?
  success       Boolean   @default(true)
  errorMsg      String?
  userConfirmed Boolean?
  confirmedAt   DateTime?

  @@index([createdAt])
  @@index([source])
  @@index([success])
  @@index([userConfirmed])
}

model EntryTag {
  entryId      String
  tagId        String
  transactions TxRecord @relation(fields: [entryId], references: [id], onDelete: Cascade)
  Tag          Tag      @relation(fields: [tagId], references: [id])

  @@id([entryId, tagId])
}

model FundConfirmDays {
  id             String   @id @default(cuid())
  accountId      String
  fundCode       String
  days           Int
  redeemCostDays Int      @default(1)
  arrivalDays    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  effectiveDate  DateTime @default(now())
  Account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, fundCode])
  @@index([accountId, fundCode])
  @@index([effectiveDate])
}

model FundFeeRate {
  id            String      @id @default(cuid())
  accountId     String
  fundCode      String
  rate          Decimal     @db.Decimal(10, 6)
  effectiveDate DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  feeType       FundFeeType @default(buy)
  Account       Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, fundCode, feeType])
  @@index([effectiveDate])
}

model FundHolding {
  id               String   @id @default(cuid())
  accountId        String
  fundCode         String
  fundName         String?
  units            Decimal  @default(0) @db.Decimal(20, 6)
  avgCost          Decimal  @default(0) @db.Decimal(20, 6)
  cost             Decimal  @default(0) @db.Decimal(18, 2)
  nav              Decimal? @db.Decimal(20, 6)
  pendingCost      Decimal  @default(0) @db.Decimal(18, 2)
  updatedAt        DateTime @default(now()) @updatedAt
  historicalProfit Decimal  @default(0) @db.Decimal(18, 2)
  Account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, fundCode])
  @@index([accountId])
  @@index([fundCode])
}

model FundNavCache {
  id            String   @id @default(cuid())
  fundCode      String
  navDate       DateTime
  nav           Decimal  @db.Decimal(20, 6)
  cumNav        Decimal? @db.Decimal(20, 6)
  name          String?
  sgzt          String? // 鐢宠喘鐘舵€侊紙寮€鏀剧敵璐€佹殏鍋滅敵璐€侀檺鍒跺ぇ棰濈敵璐瓑锛?
  purchaseLimit Int? // 鐢宠喘鏃ヤ笂闄愰噾棰濓紙鍏冿級锛屼粠澶╁ぉ鍩洪噾璇︽儏椤佃В鏋?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([fundCode, navDate])
  @@index([fundCode])
  @@index([navDate])
}

model FundQueryApi {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  baseUrl     String
  apiKey      String?
  priority    Int        @default(0)
  isActive    Boolean    @default(true)
  householdId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
  Account     Account[]
  Household   Household? @relation(fields: [householdId], references: [id])
}

model FundSnapshot {
  id              String   @id @default(cuid())
  accountId       String
  snapshotDate    DateTime
  totalCost       Decimal  @default(0) @db.Decimal(18, 2)
  marketValue     Decimal  @default(0) @db.Decimal(18, 2)
  floatingPnL     Decimal  @default(0) @db.Decimal(18, 2)
  floatingPnLRate Decimal  @default(0) @db.Decimal(18, 6)
  units           Decimal  @default(0) @db.Decimal(20, 6)
  nav             Decimal? @db.Decimal(20, 6)
  source          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  Account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, snapshotDate])
  @@index([accountId])
  @@index([snapshotDate])
}

model Household {
  id                String              @id @default(cuid())
  name              String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @default(now()) @updatedAt
  Account           Account[]
  AccountGroup      AccountGroup[]
  Category          Category[]
  EmailAccount      EmailAccount[]
  FundQueryApi      FundQueryApi[]
  ImportBatch       ImportBatch[]
  InsuranceProductMaster InsuranceProductMaster[]
  InsuranceProduct  InsuranceProduct[]
  Institution       Institution[]
  RegularInvestPlan RegularInvestPlan[]
  Tag               Tag[]
  User              User[]
  transactions      TxRecord[]
}

model ImportBatch {
  id           String     @id @default(cuid())
  source       String?
  note         String?
  rawText      String?
  householdId  String?
  createdAt    DateTime   @default(now())
  Household    Household? @relation(fields: [householdId], references: [id])
  transactions TxRecord[]
}

model Institution {
  id          String     @id @default(cuid())
  name        String
  shortName   String?
  type        String?
  householdId String?
  Account     Account[]
  InsuranceProductMaster InsuranceProductMaster[]
  InsuranceProduct InsuranceProduct[]
  Household   Household? @relation(fields: [householdId], references: [id])

  @@index([householdId, name])
}

model InsuranceProductMaster {
  id             String                 @id @default(cuid())
  name           String
  shortName      String?
  productType    InsuranceProductType   @default(other)
  accountingType InsuranceAccountingType @default(asset)
  currency       String                 @default("CNY")
  householdId    String
  institutionId  String
  note           String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @default(now()) @updatedAt
  Household      Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  Institution    Institution            @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  InsuranceProduct InsuranceProduct[]

  @@unique([householdId, institutionId, name, productType])
  @@index([householdId, productType])
  @@index([institutionId])
}

model RegularInvestPlan {
  id                                               String              @id @default(cuid())
  accountId                                        String
  cashAccountId                                    String?
  fundCode                                         String
  fundName                                         String?
  amount                                           Decimal             @db.Decimal(18, 2)
  intervalUnit                                     IntervalUnit        @default(month)
  intervalValue                                    Int                 @default(1)
  nextRunDate                                      DateTime
  lastRunDate                                      DateTime?
  feeRate                                          Decimal?            @db.Decimal(10, 6)
  confirmDays                                      Int?
  arrivalDays                                      Int?                @default(2)
  createdAt                                        DateTime            @default(now())
  updatedAt                                        DateTime            @default(now()) @updatedAt
  accountName                                      String
  cashAccountName                                  String?
  endDate                                          DateTime?
  executedRuns                                     Int                 @default(0)
  fundProductType                                  FundProductType?
  memo                                             String?
  startDate                                        DateTime
  status                                           RegularInvestStatus @default(active)
  totalRuns                                        Int?
  executionDay                                     Int?
  skipPendingPreceding                             Boolean             @default(true)
  householdId                                      String?
  Account_RegularInvestPlan_accountIdToAccount     Account             @relation("RegularInvestPlan_accountIdToAccount", fields: [accountId], references: [id], onDelete: Cascade)
  Account_RegularInvestPlan_cashAccountIdToAccount Account?            @relation("RegularInvestPlan_cashAccountIdToAccount", fields: [cashAccountId], references: [id])
  Household                                        Household?          @relation(fields: [householdId], references: [id])

  @@index([accountId])
  @@index([fundCode])
  @@index([nextRunDate])
  @@index([status])
  @@index([householdId])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model EmailAccount {
  id           String   @id @default(cuid())
  householdId  String
  label        String
  username     String
  imapHost     String
  imapPort     Int      @default(993)
  imapSecure   Boolean  @default(true)
  outboundType String   @default("smtp") // "smtp" | "resend"
  smtpHost     String?
  smtpPort     Int?     @default(465)
  smtpSecure   Boolean? @default(true)
  smtpFrom     String?
  resendApiKey String?
  resendFrom   String?
  password     String
  mailbox      String   @default("INBOX")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

model Tag {
  id          String     @id @default(cuid())
  name        String
  color       String?
  householdId String?
  EntryTag    EntryTag[]
  Household   Household? @relation(fields: [householdId], references: [id])

  @@index([householdId, name])
}

model User {
  id                 String               @id @default(cuid())
  name               String
  email              String?
  role               String               @default("admin")
  isSystem           Boolean              @default(false)
  passwordHash       String?
  householdId        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @default(now()) @updatedAt
  Account            Account[]
  Household          Household?           @relation(fields: [householdId], references: [id])
  InsuranceProduct   InsuranceProduct[]   @relation("InsuranceProduct_insuredUserIdToUser")
  UserSettings       UserSettings?
  PasswordResetToken PasswordResetToken[]

  @@index([email])
}

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  // IMAP 收件
  emailHost     String?
  emailPort     Int?
  emailSecure   Boolean  @default(true)
  emailUser     String?
  emailPassword String?
  emailMailbox  String   @default("INBOX")
  // SMTP 发件
  smtpHost      String?
  smtpPort      Int?
  smtpSecure    Boolean  @default(true)
  smtpUser      String?
  smtpPass      String?
  smtpFrom      String?
  // Resend 发件
  resendApiKey  String?
  resendFrom    String?
  // 功能开关
  passwordResetEnabled Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  colorScheme   String   @default("red_up_green_down")
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  ip        String?
  userAgent String?

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model InsuranceProduct {
  id             String                 @id @default(cuid())
  name           String
  shortName      String?
  productMasterId String?
  productType    InsuranceProductType   @default(other)
  accountingType InsuranceAccountingType @default(asset)
  policyNo       String?
  status         InsuranceStatus        @default(active)
  currency       String                 @default("CNY")
  householdId    String
  accountId      String
  institutionId  String?
  ownerGroupId   String?
  insuredUserId  String?
  beneficiaryName String?
  startDate      DateTime?
  effectiveDate  DateTime?
  maturityDate   DateTime?
  premiumMode    String?
  premiumFrequencyMonths Int?
  premiumAmount  Decimal?               @db.Decimal(18, 2)
  paymentTermYears Decimal?             @db.Decimal(10, 2)
  coverageTermYears Decimal?            @db.Decimal(10, 2)
  coverageAmount Decimal?               @db.Decimal(18, 2)
  cashValueEnabled Boolean              @default(true)
  note           String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @default(now()) @updatedAt
  ProductMaster  InsuranceProductMaster? @relation(fields: [productMasterId], references: [id], onDelete: SetNull)
  Account        Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  Household      Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  Institution    Institution?           @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  OwnerGroup     AccountGroup?          @relation(fields: [ownerGroupId], references: [id], onDelete: SetNull)
  InsuredUser    User?                  @relation("InsuranceProduct_insuredUserIdToUser", fields: [insuredUserId], references: [id], onDelete: SetNull)
  TxRecord       TxRecord[]

  @@index([productMasterId])
  @@index([householdId, productType])
  @@index([householdId, accountingType])
  @@index([accountId])
  @@index([institutionId])
  @@index([ownerGroupId])
  @@index([insuredUserId])
  @@unique([householdId, accountId, name, policyNo])
}

model TxRecord {
  id                  String            @id @default(cuid())
  date                DateTime
  type                TransactionType
  amount              Decimal           @db.Decimal(18, 2)
  accountId           String
  accountName         String
  toAccountId         String?
  toAccountName       String?
  categoryId          String?
  categoryName        String?
  fundCode            String?
  fundProductType     FundProductType?
  confirmDate         DateTime?
  statementMonth      String?           @db.VarChar(7)
  note                String?
  toNote              String?
  deletedAt           DateTime?
  importBatchId       String?
  householdId         String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @default(now()) @updatedAt
  currency            String            @default("CNY")
  paymentChannelId    String?
  paymentChannelName  String?
  counterpartyInstitutionId   String?
  counterpartyInstitutionName String?
  status              TransactionStatus @default(posted)
  fundArrivalAmount   Decimal?          @db.Decimal(18, 2)
  fundArrivalDate     DateTime?
  depositAnnualRate   Decimal?          @db.Decimal(10, 6)
  depositInterest     Decimal?          @db.Decimal(18, 2)
  depositSourceEntryId String?
  fundConfirmDate     DateTime?
  fundFee             Decimal?          @db.Decimal(18, 2)
  fundNav             Decimal?          @db.Decimal(18, 6)
  fundSubtype         FundSubtype?
  fundUnits           Decimal?          @db.Decimal(20, 6)
  realizedProfit      Decimal?          @db.Decimal(18, 2)
  regularInvestPlanId String?
  fundName            String?
  insuranceProductId  String?
  source              String?           @default("manual")
  Attachment          Attachment[]
  EntryTag            EntryTag[]
  account             Account           @relation("transactions_accountIdToAccount", fields: [accountId], references: [id])
  Category            Category?         @relation(fields: [categoryId], references: [id])
  Household           Household?        @relation(fields: [householdId], references: [id])
  ImportBatch         ImportBatch?      @relation(fields: [importBatchId], references: [id])
  InsuranceProduct    InsuranceProduct? @relation(fields: [insuranceProductId], references: [id], onDelete: SetNull)
  toAccount           Account?          @relation("transactions_toAccountIdToAccount", fields: [toAccountId], references: [id])

  @@index([accountId, date])
  @@index([accountId, statementMonth])
  @@index([counterpartyInstitutionId])
  @@index([deletedAt])
  @@index([depositSourceEntryId])
  @@index([insuranceProductId])
  @@index([regularInvestPlanId])
  @@index([toAccountId, fundProductType])
  @@index([type])
  @@map("transactions")
}

model CommandTestResult {
  id          String   @id @default(cuid())
  index       Int
  input       String
  rawResponse String   @default("")
  field       String?
  operation   String?
  value       String?
  isSuccess   Boolean  @default(false)
  error       String?
  latencyMs   Int?
  modelName   String?
  createdAt   DateTime @default(now())
}

model CommandAlias {
  id        String   @id @default(cuid())
  key       String
  value     String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([category, key])
  @@index([category])
}

enum AccountKind {
  cash
  bank_debit
  bank_credit
  ewallet
  deposit
  investment
  loan
  other
  insurance
}

enum DebtDirection {
  payable
  receivable
}

enum CostBasisMethod {
  moving_avg
  fifo
  lifo
}

enum FundFeeType {
  buy
  redeem
}

enum FundProductType {
  fund
  money
  wealth
  deposit
}

enum FundSubtype {
  buy
  redeem
  dividend_reinvest
  dividend_cash
  regular_invest
  switch_in
  switch_out
  buy_failed
}

enum InsuranceProductType {
  savings
  dividend
  annuity
  universal
  investment_linked
  critical_illness
  medical
  accident
  term_life
  whole_life
  other
}

enum InsuranceAccountingType {
  asset
  protection
  hybrid
}

enum InsuranceStatus {
  active
  matured
  surrendered
  lapsed
}

enum IntervalUnit {
  day
  week
  biweek
  month
}

enum RegularInvestStatus {
  active
  paused
  stopped
  completed
}

enum TransactionStatus {
  pending
  posted
  void
}

enum TransactionType {
  expense
  income
  transfer
  investment
}
