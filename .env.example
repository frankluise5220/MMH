# NAS/Docker 部署建议让用户自己指定 DB 账号密码（用于 Postgres 容器初始化 + App 连接）
POSTGRES_DB="openclaw"
POSTGRES_USER="openclaw"
POSTGRES_PASSWORD="CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD"

# PostgreSQL 数据库连接（本地直接运行时用 localhost；docker-compose 会自动覆盖为连接 postgres 容器）
DATABASE_URL="postgresql://openclaw:openclaw@localhost:5433/openclaw?schema=public"

# AI 代理配置（可选，用于账单识别等功能）
LOCAL_AI_API_KEY="your-api-key"
LOCAL_AI_BASE_URL="http://localhost:11434/v1"
LOCAL_AI_MODEL_NAME="gpt-4o"

# 账单导入 API 密钥
STATEMENT_API_KEY="CHANGE_ME_TO_A_LONG_RANDOM_TOKEN"

# 管理员密码
ADMIN_PASSWORD="CHANGE_ME_TO_A_SECURE_PASSWORD"

# 密码找回（邮件）
PASSWORD_RESET_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Prisma 引擎类型
PRISMA_CLIENT_ENGINE_TYPE="binary"
