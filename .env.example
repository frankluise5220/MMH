POSTGRES_DB="mmh"
POSTGRES_USER="mmh-fs"
POSTGRES_PASSWORD="CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD"

DATABASE_URL="postgresql://mmh-fs:CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD@localhost:5433/mmh?schema=public"

LOCAL_AI_API_KEY="your-api-key"
LOCAL_AI_BASE_URL="http://localhost:11434/v1"
LOCAL_AI_MODEL_NAME="gpt-4o"

STATEMENT_API_KEY=""

# Web-triggered Docker updater. The install script generates MMH_UPDATE_TOKEN.
MMH_UPDATE_TOKEN=""
MMH_UPDATER_URL="http://updater:7788"
MMH_UPDATER_IMAGE="ghcr.io/frankluise5220/mmh-updater:latest"
MMH_COMPOSE_PROJECT="mmh"

PASSWORD_RESET_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Security hardening:
# - Production HTTPS cookies are Secure by default. Plain HTTP requests use non-Secure cookies so trusted LAN deployments can log in.
# - Set MMH_INSECURE_COOKIES=1 only if a trusted HTTP proxy makes the app unable to detect the original request protocol.
# - Enable HSTS only after confirming the public site is always served through HTTPS.
MMH_INSECURE_COOKIES="0"
MMH_ENABLE_HSTS="0"
# Optional app-level Host allowlist. Empty means allow any Host header.
# Use this when exposing MMH through fixed domains or reverse proxy hosts.
# Example: MMH_ALLOWED_HOSTS="mmh.example.com,192.168.1.100,localhost,127.0.0.1"
MMH_ALLOWED_HOSTS=""

RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"

SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

PRISMA_CLIENT_ENGINE_TYPE="binary"

# Git update config (optional; defaults to origin/main of the current repo)
# MMH_GIT_REMOTE="origin"
# MMH_GIT_BRANCH="main"
# MMH_UPDATE_SOURCE_URL="https://github.com/frankluise5220/MMH.git"

# Docker image config (optional). Users can change this in System Update.
# MMH_IMAGE_SOURCE: auto | ghcr | dockerproxy | nju | daocloud | custom
MMH_IMAGE_SOURCE="auto"
MMH_APP_IMAGE="ghcr.io/frankluise5220/mmh:latest"
MMH_UPDATER_IMAGE="ghcr.io/frankluise5220/mmh-updater:latest"
CUSTOM_MMH_APP_IMAGE=""
CUSTOM_MMH_UPDATER_IMAGE=""
# If GHCR is slow from your network, use one mirror/proxy instead:
# MMH_APP_IMAGE="ghcr.dockerproxy.net/frankluise5220/mmh:latest"
# MMH_UPDATER_IMAGE="ghcr.dockerproxy.net/frankluise5220/mmh-updater:latest"
# MMH_APP_IMAGE="ghcr.m.daocloud.io/frankluise5220/mmh:latest"
# MMH_UPDATER_IMAGE="ghcr.m.daocloud.io/frankluise5220/mmh-updater:latest"
# MMH_APP_IMAGE="ghcr.nju.edu.cn/frankluise5220/mmh:latest"
# MMH_UPDATER_IMAGE="ghcr.nju.edu.cn/frankluise5220/mmh-updater:latest"
NODE_IMAGE="node:20-bookworm"
NODE_BUILD_IMAGE="node:20-bookworm"
NODE_RUNTIME_IMAGE="node:20-bookworm"
POSTGRES_IMAGE="postgres:15-alpine"
