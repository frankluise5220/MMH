# NAS/Docker 部署建议让用户自己指定 DB 账号密码（用于 Postgres 容器初始化 + App 连接）
# 数据库密码同时用于"系统初始化"操作验证
POSTGRES_DB="mmh"
POSTGRES_USER="mmh-fs"
POSTGRES_PASSWORD="CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD"

# PostgreSQL 数据库连接（本地直接运行时用 localhost；docker-compose 会自动覆盖为连接 postgres 容器）
DATABASE_URL="postgresql://mmh-fs:CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD@localhost:5433/mmh?schema=public"

# AI 代理配置（可选，用于账单识别等功能）
LOCAL_AI_API_KEY="your-api-key"
LOCAL_AI_BASE_URL="http://localhost:11434/v1"
LOCAL_AI_MODEL_NAME="gpt-4o"

# 账单导入/外部接入 API 密钥（可选；需要开放外部接入时再在系统设置中生成/填写）
STATEMENT_API_KEY=""

# 密码找回（邮件）
PASSWORD_RESET_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Resend 邑件服务（推荐，HTTP API 方式更简单可靠）
# 获取 API Key: https://resend.com/api-keys
# 仅供本地开发调试；Docker/生产发布默认不会读取这里的 RESEND_API_KEY，请在系统设置 > 邮箱设置里填写并保存。
# 测试阶段可用 onboarding@resend.dev 发件地址（只能发给自己注册 Resend 的邮箱）
# 正式使用需在 Cloudflare DNS 配置域名验证后使用自己的域名发件地址
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"

# SMTP 邑件服务（备选，传统方式）
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Prisma 引擎类型
PRISMA_CLIENT_ENGINE_TYPE="binary"

# Git 更新相关配置（可选；默认 origin/main）
MMH_GIT_REMOTE="origin"
MMH_GIT_BRANCH="main"

# Docker 基础镜像（可选；NAS 默认镜像代理异常时可改成可访问的镜像地址）
NODE_IMAGE="node:20-bookworm"
NODE_BUILD_IMAGE="node:20-bookworm"
NODE_RUNTIME_IMAGE="node:20-bookworm-slim"
POSTGRES_IMAGE="postgres:15-alpine"
